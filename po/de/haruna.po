#: src/qml/Settings/VideoSettings.qml:85
msgctxt "@title"
msgid "Screenshots"
msgstr "Bildschirmfotos"

#: src/qml/Settings/VideoSettings.qml:94
msgctxt "@label:listbox"
msgid "Format"
